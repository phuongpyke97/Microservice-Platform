    {
      "name": "File Upload Flow (MinIO)",
      "item": [
        {
          "name": "Get Presigned Upload URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/file-service/api/files/presigned/upload?originalName=guitar_calm.mp3&contentType=audio/mpeg",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "file-service",
                "api",
                "files",
                "presigned",
                "upload"
              ],
              "query": [
                {
                  "key": "originalName",
                  "value": "guitar_calm.mp3",
                  "description": "Original file name of the audio"
                },
                {
                  "key": "contentType",
                  "value": "audio/mpeg",
                  "description": "MIME type (audio/mpeg for MP3, audio/wav for WAV)"
                }
              ]
            },
            "description": "Request a presigned URL to upload a file directly to the MinIO temporary bucket. Returns the file ID and the upload URL."
          },
          "response": []
        },
        {
          "name": "Upload File to MinIO (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "audio/mpeg",
                "type": "text"
              }
            ],
            "body": {
              "mode": "file",
              "file": {
                "src": ""
              }
            },
            "url": {
              "raw": "{{presignedUrl}}",
              "host": [
                "{{presignedUrl}}"
              ]
            },
            "description": "Upload file directly to MinIO bucket via PUT using the presigned URL returned from the 'Get Presigned Upload URL' endpoint. Note: Do NOT use gatewy or Bearer token header for this request, it goes directly to MinIO."
          },
          "response": []
        },
        {
          "name": "Confirm Upload Success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetBucket\": \"audio\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/file-service/api/files/{{fileId}}/confirm",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "file-service",
                "api",
                "files",
                "{{fileId}}",
                "confirm"
              ]
            },
            "description": "Confirm that upload was successful. Moves the file from the temporary bucket to the main 'audio' bucket and returns the public external URL."
          },
          "response": []
        }
      ],
      "description": "Endpoints to get presigned upload URLs, upload files directly to MinIO, and confirm the upload completion."
    },
    {
      "name": "Ringtones Management",
      "item": [
        {
          "name": "Create Ringtone Metadata",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Warm Morning Acoustic\",\n  \"artistName\": \"Sunny Vibes\",\n  \"audioUrl\": \"http://localhost:9000/media-audio/e05b3f7f-f7d9-482a-a5f1-32ad51cf216b.mp3\",\n  \"coverImageUrl\": \"http://localhost:9000/media-images/cover.jpg\",\n  \"durationSeconds\": null,\n  \"featured\": true,\n  \"mood\": \"Calm\",\n  \"status\": true,\n  \"categoryId\": 1\n}"
