              "raw": "{\n  \"title\": \"Warm Morning Acoustic (Updated)\",\n  \"artistName\": \"Sunny Vibes\",\n  \"audioUrl\": \"http://localhost:9000/media-audio/e05b3f7f-f7d9-482a-a5f1-32ad51cf216b.mp3\",\n  \"coverImageUrl\": \"http://localhost:9000/media-images/cover-new.jpg\",\n  \"durationSeconds\": null,\n  \"featured\": false,\n  \"mood\": \"Romantic\",\n  \"status\": true,\n  \"categoryId\": 1\n}"
