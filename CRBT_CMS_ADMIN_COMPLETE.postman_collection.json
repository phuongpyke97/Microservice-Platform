        {
          "name": "Safe Delete Ringtone",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/crbt-community-library/library/ringtones/{{ringtoneId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "crbt-community-library",
                "library",
                "ringtones",
                "{{ringtoneId}}"
              ]
            },
            "description": "Safe deletes a ringtone. Before deleting the metadata row and physical MinIO audio files, it archives the downloads/selections count into 'ringtone_deleted_history' to preserve reporting statistics."
          },
          "response": []
        },
        {
          "name": "Get Random Ringtone",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/crbt-community-library/library/ringtones/random?genre=Acoustic",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "crbt-community-library",
                "library",
                "ringtones",
                "random"
              ],
              "query": [
                {
                  "key": "genre",
                  "value": "Acoustic",
                  "description": "Optional category name filter"
                }
              ]
            },
            "description": "Get a random active ringtone (primarily used for user CRBT settings preview)."
          },
          "response": []
        }
      ],
      "description": "Ringtone metadata management APIs including CRUD, search, statistics, CSV export, and safe-deletion."
