{
  "info": {
    "_postman_id": "7f921f64-4e2b-426b-9528-98e35cf46ab1",
    "name": "CRBT_CMS_ADMIN",
    "description": "Collection of APIs for CRBT CMS Admin Page including file uploads, categories management, ringtone management, statistics, and reports.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "File Upload Flow (MinIO)",
      "item": [
        {
          "name": "Get Presigned Upload URL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/file-service/api/files/presigned/upload?originalName=guitar_calm.mp3&contentType=audio/mpeg",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "file-service",
                "api",
                "files",
                "presigned",
                "upload"
              ],
              "query": [
                {
                  "key": "originalName",
                  "value": "guitar_calm.mp3",
                  "description": "Original file name of the audio"
                },
                {
                  "key": "contentType",
                  "value": "audio/mpeg",
                  "description": "MIME type (audio/mpeg for MP3, audio/wav for WAV)"
                }
              ]
            },
            "description": "Request a presigned URL to upload a file directly to the MinIO temporary bucket. Returns the file ID and the upload URL."
          },
          "response": []
        },
        {
          "name": "Upload File to MinIO (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "audio/mpeg",
                "type": "text"
              }
            ],
            "body": {
              "mode": "file",
              "file": {
                "src": ""
              }
            },
            "url": {
              "raw": "{{presignedUrl}}",
              "host": [
                "{{presignedUrl}}"
              ]
            },
            "description": "Upload file directly to MinIO bucket via PUT using the presigned URL returned from the 'Get Presigned Upload URL' endpoint. Note: Do NOT use gatewy or Bearer token header for this request, it goes directly to MinIO."
          },
          "response": []
        },
        {
          "name": "Confirm Upload Success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetBucket\": \"audio\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/file-service/api/files/{{fileId}}/confirm",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "file-service",
                "api",
                "files",
                "{{fileId}}",
                "confirm"
              ]
            },
            "description": "Confirm that upload was successful. Moves the file from the temporary bucket to the main 'audio' bucket and returns the public external URL."
          },
          "response": []
        }
      ],
      "description": "Endpoints to get presigned upload URLs, upload files directly to MinIO, and confirm the upload completion."
    },
    {
      "name": "Categories Management",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acoustic\",\n  \"description\": \"Soft and calming acoustic guitar tracks\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/crbt-community-library/library/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "crbt-community-library",
                "library",
                "categories"
              ]
            },
            "description": "Create a new ringtone category."
          },
          "response": []
        },
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/crbt-community-library/library/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "crbt-community-library",
                "library",
                "categories"
              ]
            },
            "description": "List all active ringtone categories."
          },
          "response": []
        }
      ],
      "description": "Category CRUD endpoints for grouping ringtones."
    },
    {
      "name": "Ringtones Management",
      "item": [
        {
          "name": "Create Ringtone Metadata",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Warm Morning Acoustic\",\n  \"artistName\": \"Sunny Vibes\",\n  \"audioUrl\": \"http://localhost:9000/media-audio/e05b3f7f-f7d9-482a-a5f1-32ad51cf216b.mp3\",\n  \"coverImageUrl\": \"http://localhost:9000/media-images/cover.jpg\",\n  \"durationSeconds\": null,\n  \"featured\": true,\n  \"mood\": \"Calm\",\n  \"status\": true,\n  \"categoryId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/crbt-community-library/library/ringtones",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "crbt-community-library",
                "library",
                "ringtones"
              ]
            },
            "description": "Create ringtone metadata. The backend automatically performs validation on the audio file size (<50MB), duration (<5 mins), and checks for vocal presence (rejects vocal music)."
          },
          "response": []
        },
        {
          "name": "Update Ringtone Metadata",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Warm Morning Acoustic (Updated)\",\n  \"artistName\": \"Sunny Vibes\",\n  \"audioUrl\": \"http://localhost:9000/media-audio/e05b3f7f-f7d9-482a-a5f1-32ad51cf216b.mp3\",\n  \"coverImageUrl\": \"http://localhost:9000/media-images/cover-new.jpg\",\n  \"durationSeconds\": null,\n  \"featured\": false,\n  \"mood\": \"Romantic\",\n  \"status\": true,\n  \"categoryId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/crbt-community-library/library/ringtones/{{ringtoneId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "crbt-community-library",
                "library",
                "ringtones",
                "{{ringtoneId}}"
              ]
            },
            "description": "Update existing ringtone metadata. Trigger validation if audio URL changes."
          },
          "response": []
        },
        {
          "name": "Update Ringtone Status",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/crbt-community-library/library/ringtones/{{ringtoneId}}/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "crbt-community-library",
                "library",
                "ringtones",
                "{{ringtoneId}}",
                "status"
              ]
            },
            "description": "Quickly toggle a ringtone's active status (active/inactive)."
          },
          "response": []
        },
        {
          "name": "Search & Filter Ringtones",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/crbt-community-library/library/ringtones/search?q=Morning&categoryId=1&status=true&page=0&size=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "crbt-community-library",
                "library",
                "ringtones",
                "search"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "Morning",
                  "description": "Search keyword for title/artist name (real-time search)"
                },
                {
                  "key": "categoryId",
                  "value": "1",
                  "description": "Filter by category ID"
                },
                {
                  "key": "status",
                  "value": "true",
                  "description": "Filter by active status (true/false)"
                },
                {
                  "key": "createdFrom",
                  "value": "2026-05-01",
                  "disabled": true,
                  "description": "Filter upload start date (YYYY-MM-DD)"
                },
                {
                  "key": "createdTo",
                  "value": "2026-05-30",
                  "disabled": true,
                  "description": "Filter upload end date (YYYY-MM-DD)"
                },
                {
                  "key": "selectionCountFrom",
                  "value": "0",
                  "disabled": true,
                  "description": "Filter min download/selection count"
                },
                {
                  "key": "selectionCountTo",
                  "value": "1000",
                  "disabled": true,
                  "description": "Filter max download/selection count"
                },
                {
                  "key": "page",
                  "value": "0",
                  "description": "Page index (0-based)"
                },
                {
                  "key": "size",
                  "value": "20",
                  "description": "Page size"
                }
              ]
            },
            "description": "Search ringtones with multiple criteria (keyword, category, status, date range, selection count range) and pagination."
          },
          "response": []
        },
        {
          "name": "Statistics Dashboard",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/crbt-community-library/library/ringtones/statistics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "crbt-community-library",
                "library",
                "ringtones",
                "statistics"
              ]
            },
            "description": "Fetch overall statistics including total active tracks, total categories, and total selection count (including active and archived deleted tracks statistics)."
          },
          "response": []
        },
        {
          "name": "Export CSV Report",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/crbt-community-library/library/ringtones/export?q=Morning&categoryId=1&status=true",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "crbt-community-library",
                "library",
                "ringtones",
                "export"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "Morning"
                },
                {
                  "key": "categoryId",
                  "value": "1"
                },
                {
                  "key": "status",
                  "value": "true"
                }
              ]
            },
            "description": "Export the filtered ringtones list into a CSV format (supports UTF-8 with BOM for correct Excel rendering)."
          },
          "response": []
        },
        {
          "name": "Safe Delete Ringtone",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/crbt-community-library/library/ringtones/{{ringtoneId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "crbt-community-library",
                "library",
                "ringtones",
                "{{ringtoneId}}"
              ]
            },
            "description": "Safe deletes a ringtone. Before deleting the metadata row and physical MinIO audio files, it archives the downloads/selections count into 'ringtone_deleted_history' to preserve reporting statistics."
          },
          "response": []
        },
        {
          "name": "Get Random Ringtone",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/crbt-community-library/library/ringtones/random?genre=Acoustic",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "crbt-community-library",
                "library",
                "ringtones",
                "random"
              ],
              "query": [
                {
                  "key": "genre",
                  "value": "Acoustic",
                  "description": "Optional category name filter"
                }
              ]
            },
            "description": "Get a random active ringtone (primarily used for user CRBT settings preview)."
          },
          "response": []
        }
      ],
      "description": "Ringtone metadata management APIs including CRUD, search, statistics, CSV export, and safe-deletion."
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
