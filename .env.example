# Copy to .env and fill in real values. Do NOT commit .env.

# ─── Database ───────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=

AUTH_DB=auth_db
FILE_DB=file_db
PAYMENT_DB=payment_db
WALLET_DB=wallet_db
AUDIT_DB=audit_db
NOTIFICATION_DB=notification_db
CAMPAIGN_DB=campaign_db
COMMUNITY_DB=community_db
AUDIO_GEN_DB=audio_gen_db
CREDIT_TX_DB=credit_tx_db
ADAPTER_DB=adapter_db

# ─── Redis ───────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── RabbitMQ ────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=
RABBITMQ_PASSWORD=

# ─── MinIO ───────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_IMAGES=media-images
MINIO_BUCKET_AUDIO=media-audio
MINIO_BUCKET_TEMP=media-temp
MINIO_BUCKET_PRIVATE=media-private

# ─── Auth (JWT for admin) ────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRY_ACCESS_MINUTES=15
JWT_EXPIRY_REFRESH_DAYS=7
BCRYPT_STRENGTH=12

# ─── CRBT Token (từ nhà mạng Mytel) ─────────────────────────────
CRBT_SHARED_SECRET=
CRBT_VERIFY_ENDPOINT=

# ─── Eureka ──────────────────────────────────────────────────────
EUREKA_URL=http://localhost:8761/eureka
EUREKA_USER=
EUREKA_PASSWORD=

# ─── Config Server ───────────────────────────────────────────────
CONFIG_SERVER_URL=http://localhost:8888

# ─── AI / External ───────────────────────────────────────────────
GEMINI_API_KEY=
EDGE_TTS_RATE=+0%
EDGE_TTS_PITCH=+0Hz

# ─── CMS Mytone ──────────────────────────────────────────────────
MYTONE_API_URL=
MYTONE_API_KEY=

# ─── Monitoring ──────────────────────────────────────────────────
LOKI_URL=http://localhost:3100
GRAFANA_USER=
GRAFANA_PASSWORD=

# ─── AI Media Worker (Python) ────────────────────────────────────
AI_WORKER_HOST=localhost
AI_WORKER_GRPC_PORT=8765
AI_WORKER_HTTP_PORT=8765
