# ==============================================================================
# Microservice Platform - Environment Variables Example
# Copy this file to .env and modify the values for your environment.
# ==============================================================================

# --- Versions ---
POSTGRES_VERSION=16.2
REDIS_VERSION=7.2.4-alpine
RABBITMQ_VERSION=3.12-management-alpine
MINIO_VERSION=latest
LOKI_VERSION=2.9.4
PROMTAIL_VERSION=2.9.4
PROMETHEUS_VERSION=v2.51.0
GRAFANA_VERSION=10.4.2

# --- Infrastructure Ports (External/Host Side) ---
EUREKA_PORT=8761
CONFIG_SERVER_PORT=8889
API_GATEWAY_PORT_EXTERNAL=18080

# --- Database (PostgreSQL) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_PORT_PUBLIC=15433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=platform_db

# Individual Service DBs
AUTH_DB=auth_db
FILE_DB=file_db
PAYMENT_DB=payment_db
WALLET_DB=wallet_db
AUDIT_DB=audit_db
NOTIFICATION_DB=notification_db
CAMPAIGN_DB=campaign_db
COMMUNITY_DB=community_db
AUDIO_GEN_DB=audio_gen_db
CREDIT_TX_DB=credit_tx_db
ADAPTER_DB=adapter_db

# --- Cache & Lock (Redis) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Message Broker (RabbitMQ) ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- Storage (MinIO) ---
MINIO_ENDPOINT=http://minio:9000
MINIO_EXTERNAL_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

MINIO_BUCKET_IMAGES=media-images
MINIO_BUCKET_AUDIO=media-audio
MINIO_BUCKET_AUDIO_LIB=media-audio-lib
MINIO_BUCKET_TEMP=media-temp
MINIO_BUCKET_PRIVATE=media-private

# --- Infrastructure Credentials ---
EUREKA_USER=eureka
EUREKA_PASSWORD=eureka-secret
CONFIG_SERVER_USER=configuser
CONFIG_SERVER_PASSWORD=configsecret

# --- Security & Auth ---
# Admin/CMS JWT
JWT_SECRET=platform-jwt-secret-for-dev-only-change-in-production
JWT_EXPIRY_ACCESS_MINUTES=15
JWT_EXPIRY_REFRESH_DAYS=7
BCRYPT_STRENGTH=12

# CRBT Auth (Local JWT Verify)
CRBT_SHARED_SECRET=crbt-shared-secret-dev

# --- AI & External Services ---
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=lyria-3-clip-preview
EDGE_TTS_RATE=+0%
EDGE_TTS_PITCH=+0Hz

# --- CMS Mytone Adapter ---
MYTONE_API_URL=
MYTONE_API_KEY=

# --- Python AI Worker ---
AI_WORKER_HOST=ai-media-worker
AI_WORKER_HTTP_PORT=8765
AI_WORKER_GRPC_PORT=50051

# --- Monitoring ---
LOKI_URL=http://loki:3100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Common Config ---
SPRING_PROFILES_ACTIVE=docker
LOG_LEVEL=INFO
# Lyria reconciliation daily 00:00 scheduler enablement (set to false to disable)
LYRIA_RECONCILE_SCHEDULER_ENABLED=true
