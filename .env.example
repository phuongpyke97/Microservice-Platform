# ==============================================================================
# Microservice Platform - Environment Variables Example
# Copy this file to .env and modify the values for your environment.
# ==============================================================================

# --- Versions ---
POSTGRES_VERSION=16.2
REDIS_VERSION=7.2.4-alpine
RABBITMQ_VERSION=3.12-management-alpine
MINIO_VERSION=latest
LOKI_VERSION=2.9.4
PROMTAIL_VERSION=2.9.4
PROMETHEUS_VERSION=v2.51.0
GRAFANA_VERSION=10.4.2

# --- Database (PostgreSQL) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=platform_db

# --- Cache & Lock (Redis) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Message Broker (RabbitMQ) ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- Storage (MinIO) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=http://minio:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- Infrastructure Ports (Server Side) ---
EUREKA_PORT=8761
CONFIG_SERVER_PORT=8889
API_GATEWAY_PORT_EXTERNAL=18080

# --- Infrastructure Credentials ---
EUREKA_USER=eureka
EUREKA_PASSWORD=eureka-secret
CONFIG_SERVER_USER=configuser
CONFIG_SERVER_PASSWORD=configsecret

# --- Security ---
JWT_SECRET=platform-jwt-secret-for-dev-only-change-in-production
CRBT_SHARED_SECRET=crbt-shared-secret-dev
CRBT_VERIFY_ENDPOINT=http://localhost/crbt/verify

# --- Python AI Worker ---
AI_WORKER_HOST=ai-media-worker
AI_WORKER_HTTP_PORT=8765
AI_WORKER_GRPC_PORT=50051

# --- Monitoring ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Common Config ---
SPRING_PROFILES_ACTIVE=docker
LOG_LEVEL=INFO
